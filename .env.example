# Firebase Configuration
# You can find these in Firebase Console > Project Settings > General > Your apps
# Note: The app currently uses firebase-applet-config.json for most of these,
# but it's good practice to have them here for local development.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary Configuration
# REQUIRED for product image uploads
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Admin Configuration
# The secret passcode is currently hardcoded as 'lumina2026' in firestore.rules
